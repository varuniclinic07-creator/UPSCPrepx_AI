# ═══════════════════════════════════════════════════════════════
# UPSC CSE MASTER - ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.local for development
# Copy this file to .env.production for production
# ═══════════════════════════════════════════════════════════════

# ╔═══════════════════════════════════════════════════════════════╗
# ║ DATABASE - Supabase/PostgreSQL                                 ║
# ╚═══════════════════════════════════════════════════════════════╝
POSTGRES_DB=upsc_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=           # REQUIRED: Use a strong password (min 16 chars)
DATABASE_URL=                # REQUIRED: Full connection string

# Supabase
NEXT_PUBLIC_SUPABASE_URL=    # REQUIRED: Your Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # REQUIRED: Supabase anonymous key
SUPABASE_SERVICE_ROLE_KEY=      # REQUIRED: Supabase service role key (server-side only)

# ╔═══════════════════════════════════════════════════════════════╗
# ║ REDIS - Cache & Queue (REQUIRED)                              ║
# ╚═══════════════════════════════════════════════════════════════╝
REDIS_PASSWORD=              # REQUIRED: Use a strong password
REDIS_URL=                   # REQUIRED: redis://:password@host:6379

# ╔═══════════════════════════════════════════════════════════════╗
# ║ MINIO - Object Storage                                         ║
# ╚═══════════════════════════════════════════════════════════════╝
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=         # REQUIRED: Use a strong password
MINIO_ENDPOINT=              # REQUIRED: MinIO server endpoint
MINIO_PUBLIC_HOST=           # REQUIRED: Public hostname for image URLs

# ╔═══════════════════════════════════════════════════════════════╗
# ║ AI SERVICES                                                    ║
# ╚═══════════════════════════════════════════════════════════════╝
# A4F (Alpha4Free) API
A4F_API_KEY=                 # REQUIRED: Your A4F API key
A4F_BASE_URL=https://api.a4f.co/v1

# Google Gemini (Optional)
GOOGLE_API_KEY=              # Optional: For Gemini features

# ╔═══════════════════════════════════════════════════════════════╗
# ║ AUTHENTICATION                                                 ║
# ╚═══════════════════════════════════════════════════════════════╝
# NextAuth
NEXTAUTH_SECRET=             # REQUIRED: Run: openssl rand -base64 32
NEXTAUTH_URL=                # REQUIRED: https://yourdomain.com

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=            # Optional: For Google login
GOOGLE_CLIENT_SECRET=

# ╔═══════════════════════════════════════════════════════════════╗
# ║ PAYMENTS - Razorpay                                            ║
# ╚═══════════════════════════════════════════════════════════════╝
RAZORPAY_KEY_ID=             # REQUIRED: Razorpay Key ID
RAZORPAY_KEY_SECRET=         # REQUIRED: Razorpay Key Secret
RAZORPAY_WEBHOOK_SECRET=     # REQUIRED: Webhook verification secret

# ╔═══════════════════════════════════════════════════════════════╗
# ║ SMS - Twilio                                                   ║
# ╚═══════════════════════════════════════════════════════════════╝
TWILIO_ACCOUNT_SID=          # Optional: For SMS OTP
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ╔═══════════════════════════════════════════════════════════════╗
# ║ EMAIL - Resend                                                 ║
# ╚═══════════════════════════════════════════════════════════════╝
RESEND_API_KEY=              # Optional: For transactional emails
FROM_EMAIL=noreply@yourdomain.com

# ╔═══════════════════════════════════════════════════════════════╗
# ║ AGENTIC SERVICES (OPTIONAL)                                    ║
# ╚═══════════════════════════════════════════════════════════════╝
# Leave empty to disable these optional features
AGENTIC_WEB_SEARCH_URL=      # Optional: http://89.117.60.144:8030
AUTODOC_THINKER_URL=         # Optional: http://89.117.60.144:8031
AGENTIC_FILE_SEARCH_URL=     # Optional: http://89.117.60.144:8032

# Crawl4AI (REQUIRED)
CRAWL4AI_URL=http://89.117.60.144:11235
CRAWL4AI_API_TOKEN=          # REQUIRED: For scraping service

# ╔═══════════════════════════════════════════════════════════════╗
# ║ APPLICATION CONFIG                                             ║
# ╚═══════════════════════════════════════════════════════════════╝
NEXT_PUBLIC_APP_URL=         # REQUIRED: https://yourdomain.com
NODE_ENV=production

# Admin
ADMIN_EMAILS=admin@example.com  # Comma-separated admin emails

# ╔═══════════════════════════════════════════════════════════════╗
# ║ VPS SERVICES (Coolify at 89.117.60.144:8000)                  ║
# ╚═══════════════════════════════════════════════════════════════╝

# MinIO - Object Storage
MINIO_ENDPOINT=89.117.60.144
MINIO_PORT=9000
MINIO_ACCESS_KEY=upscadmin
MINIO_SECRET_KEY=upsc2026miniopass
MINIO_USE_SSL=false

# Crawl4AI - Web Scraping
CRAWL4AI_URL=http://89.117.60.144:11235
CRAWL4AI_API_TOKEN=upsc2026crawltoken

# Cron Jobs
CRON_SECRET=                 # REQUIRED: Generate with: openssl rand -base64 32

# Plausible - Analytics
PLAUSIBLE_URL=http://89.117.60.144:8088
PLAUSIBLE_DOMAIN=aimasteryedu.in

# Mautic - Marketing Automation
MAUTIC_URL=http://89.117.60.144:8083
MAUTIC_USERNAME=              # Optional: Mautic admin username
MAUTIC_PASSWORD=              # Optional: Mautic admin password

# Uptime Kuma - Monitoring
UPTIME_KUMA_URL=http://89.117.60.144:3003
UPTIME_KUMA_PUSH_KEY=         # Optional: Push monitor key

# Autodoc & File Search
AUTODOC_THINKER_URL=http://89.117.60.144:8031
AGENTIC_FILE_SEARCH_URL=http://89.117.60.144:8032

# ╔═══════════════════════════════════════════════════════════════╗
# ║ MONITORING (OPTIONAL)                                          ║
# ╚═══════════════════════════════════════════════════════════════╝
NEXT_PUBLIC_SENTRY_DSN=      # Optional: Sentry error tracking

# ═══════════════════════════════════════════════════════════════
# NOTES:
# 1. Never commit .env files to git
# 2. Use strong, unique passwords (min 16 characters)
# 3. Rotate secrets regularly (every 90 days)
# 4. Use environment-specific values for each deployment
# ═══════════════════════════════════════════════════════════════
