{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "lib": ["ES2020"],
    "types": ["node"],
    "sourceMap": false,
    "declaration": false,
    "removeComments": true
  },
  "include": [
    "src/workers/**/*.ts",
    "src/lib/lecture-generator/**/*.ts",
    "src/lib/rate-limiter/**/*.ts",
    "src/lib/services/**/*.ts",
    "src/lib/queues/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/workers/**/*.js",
    "src/lib/**/*.js"
  ]
}
