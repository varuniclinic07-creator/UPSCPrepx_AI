# NPM Configuration for CI/CD and Coolify Deployment
# This ensures consistent behavior across different environments

# Ensure devDependencies are installed (needed for build tools)
production=false

# Use legacy peer deps to avoid peer dependency conflicts
legacy-peer-deps=true

# Disable strict SSL for corporate proxies (if needed)
# strict-ssl=false

# Set registry (default npm registry)
registry=https://registry.npmjs.org/

# Increase network timeout for slow connections
fetch-timeout=300000
fetch-retries=5

# Engine strict mode - warn but don't fail on engine mismatch
engine-strict=false

# Save exact versions to prevent version drift
save-exact=true

# Disable optional dependencies that might fail
optional=false

# Audit settings - disable in CI to speed up builds
audit=false

# Fund notifications - disable in CI
fund=false

# Progress bar - disable in CI for cleaner logs
progress=false