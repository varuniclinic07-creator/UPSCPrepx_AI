# ═══════════════════════════════════════════════════════════════
# UPSC CSE MASTER - DEVELOPMENT ENVIRONMENT
# Safe defaults for local development
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════════
# SUPABASE (Local)
# ═══════════════════════════════════════════════════════════════
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ═══════════════════════════════════════════════════════════════
# REDIS (Local)
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://:devpassword@localhost:6379
REDIS_PASSWORD=devpassword

# ═══════════════════════════════════════════════════════════════
# DATABASE (Local)
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/upsc_db

# ═══════════════════════════════════════════════════════════════
# RAZORPAY (Test Mode)
# ═══════════════════════════════════════════════════════════════
RAZORPAY_KEY_ID=rzp_test_your_test_key_id
RAZORPAY_KEY_SECRET=your_test_key_secret
WEBHOOK_SECRET=test_webhook_secret

# ═══════════════════════════════════════════════════════════════
# AI PROVIDERS (Development)
# ═══════════════════════════════════════════════════════════════
# Use test/sandbox keys for development
OPENCODE_API_KEY=your_test_opencode_key
KILO_API_KEY=your_test_kilo_key
GROQ_API_KEY=your_test_groq_key
OLLAMA_BASE_URL=http://localhost:11434

# ═══════════════════════════════════════════════════════════════
# SECURITY (Development)
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=dev-jwt-secret-minimum-32-characters-long
CRON_SECRET=dev-cron-secret
ENCRYPTION_KEY=dev-encryption-key-32-chars

# ═══════════════════════════════════════════════════════════════
# NEXTAUTH (Development)
# ═══════════════════════════════════════════════════════════════
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-min-32-chars

# Google OAuth (Development)
# GOOGLE_CLIENT_ID=your_dev_google_client_id
# GOOGLE_CLIENT_SECRET=your_dev_google_client_secret

# ═══════════════════════════════════════════════════════════════
# EMAIL (Development - Log to console)
# ═══════════════════════════════════════════════════════════════
EMAIL_FROM=noreply@localhost:3000
# SENDGRID_API_KEY= (not needed in dev - emails logged to console)

# ═══════════════════════════════════════════════════════════════
# STORAGE (Local)
# ═══════════════════════════════════════════════════════════════
# Use local storage in development
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# ═══════════════════════════════════════════════════════════════
# ANALYTICS (Disabled in Development)
# ═══════════════════════════════════════════════════════════════
# SENTRY_DSN=
# GOOGLE_ANALYTICS_ID=
# POSTHOG_API_KEY=

# ═══════════════════════════════════════════════════════════════
# RATE LIMITING (Relaxed for Development)
# ═══════════════════════════════════════════════════════════════
ENABLE_RATE_LIMITING=true
GLOBAL_RATE_LIMIT_RPM=1000

# ═══════════════════════════════════════════════════════════════
# CACHING
# ═══════════════════════════════════════════════════════════════
ENABLE_CACHING=true
CACHE_TTL_HOURS=1

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS (All enabled for Development)
# ═══════════════════════════════════════════════════════════════
ENABLE_LECTURES=true
ENABLE_MOCK_INTERVIEWS=true
ENABLE_ESSAY_EVALUATION=true
ENABLE_VIDEO_DOWNLOAD=true
ENABLE_AI_NOTES=true
ENABLE_MIND_MAPS=true
ENABLE_MCQ_PRACTICE=true
ENABLE_DOUBT_SOLVER=true
ENABLE_STUDY_PLANNER=true

# ═══════════════════════════════════════════════════════════════
# CORS (Development)
# ═══════════════════════════════════════════════════════════════
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ═══════════════════════════════════════════════════════════════
# DEBUG FLAGS
# ═══════════════════════════════════════════════════════════════
DEBUG=true
DEBUG_RATE_LIMITER=true
DEBUG_CACHE=true
DEBUG_DATABASE=true
