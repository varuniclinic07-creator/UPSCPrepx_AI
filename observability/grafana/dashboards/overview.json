{
  "dashboard": {
    "id": null,
    "uid": "upsc-overview",
    "title": "UPSC PrepX-AI Overview",
    "tags": ["upsc", "overview"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
        "type": "stat",
        "title": "System Health",
        "targets": [
          {
            "expr": "up(probe)",
            "legendFormat": "Services Up"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "green", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "type": "timeseries",
        "title": "HTTP Request Rate",
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (status_code)",
            "legendFormat": "{{ status_code }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 3,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "type": "timeseries",
        "title": "Request Latency (95th percentile)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "s"
          }
        }
      },
      {
        "id": 4,
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
        "type": "stat",
        "title": "Total Requests (24h)",
        "targets": [
          {
            "expr": "sum(increase(http_requests_total[24h]))",
            "legendFormat": "Requests"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 5,
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
        "type": "stat",
        "title": "Error Rate",
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
            "legendFormat": "Error %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
        "type": "stat",
        "title": "Active Users",
        "targets": [
          {
            "expr": "sum(active_users)",
            "legendFormat": "Users"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 7,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "type": "timeseries",
        "title": "AI Requests by Provider",
        "targets": [
          {
            "expr": "sum(rate(ai_requests_total[5m])) by (provider)",
            "legendFormat": "{{ provider }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 8,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "type": "timeseries",
        "title": "AI Token Usage",
        "targets": [
          {
            "expr": "sum(rate(ai_tokens_total[5m])) by (type)",
            "legendFormat": "{{ type }} tokens"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 9,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
        "type": "timeseries",
        "title": "AI Cost (USD)",
        "targets": [
          {
            "expr": "sum(ai_cost_total)",
            "legendFormat": "Total Cost"
          },
          {
            "expr": "sum(ai_cost_total) by (provider)",
            "legendFormat": "{{ provider }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 10,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
        "type": "piechart",
        "title": "Subscription Distribution",
        "targets": [
          {
            "expr": "sum(active_users) by (plan)",
            "legendFormat": "{{ plan }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" }
          }
        }
      },
      {
        "id": 11,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
        "type": "timeseries",
        "title": "Revenue (24h)",
        "targets": [
          {
            "expr": "sum(increase(payment_revenue_total[24h]))",
            "legendFormat": "Revenue"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 12,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
        "type": "table",
        "title": "Queue Status",
        "targets": [
          {
            "expr": "sum(queue_size) by (queue_name)",
            "legendFormat": "{{ queue_name }}"
          },
          {
            "expr": "sum(queue_active_workers) by (queue_name)",
            "legendFormat": "{{ queue_name }} workers"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "queue_name": "Queue",
                "Value": "Size"
              }
            }
          }
        ]
      },
      {
        "id": 13,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
        "type": "timeseries",
        "title": "Memory Usage",
        "targets": [
          {
            "expr": "process_memory_bytes{type=\"rss\"} / 1024 / 1024",
            "legendFormat": "RSS"
          },
          {
            "expr": "process_memory_bytes{type=\"heapUsed\"} / 1024 / 1024",
            "legendFormat": "Heap Used"
          },
          {
            "expr": "process_memory_bytes{type=\"heapTotal\"} / 1024 / 1024",
            "legendFormat": "Heap Total"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "bytes"
          }
        }
      },
      {
        "id": 14,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
        "type": "timeseries",
        "title": "CPU Usage",
        "targets": [
          {
            "expr": "process_cpu_percent",
            "legendFormat": "CPU %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "percent"
          }
        }
      },
      {
        "id": 15,
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 52 },
        "type": "alertlist",
        "title": "Active Alerts",
        "options": {
          "showOptions": "current",
          "sortOrder": "severity"
        }
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "templating": {
      "list": []
    }
  }
}
