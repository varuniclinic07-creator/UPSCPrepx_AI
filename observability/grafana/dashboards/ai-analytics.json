{
  "dashboard": {
    "id": null,
    "uid": "upsc-ai-analytics",
    "title": "AI Analytics",
    "tags": ["upsc", "ai", "analytics"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "type": "stat",
        "title": "Total AI Requests (24h)",
        "targets": [
          {
            "expr": "sum(increase(ai_requests_total[24h]))",
            "legendFormat": "Requests"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 2,
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "type": "stat",
        "title": "Total Tokens (24h)",
        "targets": [
          {
            "expr": "sum(increase(ai_tokens_total[24h]))",
            "legendFormat": "Tokens"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "type": "stat",
        "title": "AI Cost (24h)",
        "targets": [
          {
            "expr": "sum(increase(ai_cost_total[24h]))",
            "legendFormat": "Cost"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 4,
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "type": "stat",
        "title": "Fallback Rate",
        "targets": [
          {
            "expr": "sum(increase(ai_fallback_total[24h])) / sum(increase(ai_requests_total[24h])) * 100",
            "legendFormat": "Fallback %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 15 }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "type": "timeseries",
        "title": "AI Requests by Provider",
        "targets": [
          {
            "expr": "sum(rate(ai_requests_total[5m])) by (provider)",
            "legendFormat": "{{ provider }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 6,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "type": "timeseries",
        "title": "AI Request Latency by Provider",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le, provider))",
            "legendFormat": "{{ provider }} p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le, provider))",
            "legendFormat": "{{ provider }} p95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "s"
          }
        }
      },
      {
        "id": 7,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "type": "timeseries",
        "title": "Token Usage Over Time",
        "targets": [
          {
            "expr": "sum(rate(ai_tokens_total[5m])) by (type)",
            "legendFormat": "{{ type }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 8,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "type": "bargauge",
        "title": "Token Usage by Model",
        "targets": [
          {
            "expr": "sum(increase(ai_tokens_total[24h])) by (model)",
            "legendFormat": "{{ model }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 9,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "type": "timeseries",
        "title": "AI Cost by Provider",
        "targets": [
          {
            "expr": "sum(increase(ai_cost_total[1h])) by (provider)",
            "legendFormat": "{{ provider }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 10,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "type": "piechart",
        "title": "Cost Distribution",
        "targets": [
          {
            "expr": "sum(ai_cost_total) by (provider)",
            "legendFormat": "{{ provider }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" }
          }
        }
      },
      {
        "id": 11,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
        "type": "timeseries",
        "title": "AI Errors",
        "targets": [
          {
            "expr": "sum(rate(ai_errors_total[5m])) by (provider, error_type)",
            "legendFormat": "{{ provider }} - {{ error_type }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "errors/sec"
          }
        }
      },
      {
        "id": 12,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
        "type": "table",
        "title": "Provider Performance",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(ai_request_duration_seconds_bucket[1h])) by (le, provider))",
            "legendFormat": "{{ provider }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "unit": "s",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 2 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        }
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "provider",
          "type": "query",
          "query": "label_values(ai_requests_total, provider)",
          "refresh": 1,
          "multi": true,
          "includeAll": true
        }
      ]
    }
  }
}
