# ═══════════════════════════════════════════════════════════════
# AI PROVIDER CONFIGURATION - 9Router Primary + Groq + Ollama
# ═══════════════════════════════════════════════════════════════

# Primary: 9Router (UPSC Model)
PRIMARY_AI_PROVIDER=9router
UPSC_MODEL_NAME=upsc
NINE_ROUTER_BASE_URL=https://r94p885.9router.com/v1
NINE_ROUTER_API_KEY=YOUR_9ROUTER_KEY_HERE
NINE_ROUTER_RATE_LIMIT_RPM=60
NINE_ROUTER_RATE_LIMIT_CONCURRENT=20
NINE_ROUTER_MODEL=upsc

# Groq - Multi-Key Rotation & Fallback
GROQ_MODEL=groq/llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_RATE_LIMIT_RPM=30
GROQ_RATE_LIMIT_CONCURRENT=10
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_API_KEY_1=YOUR_GROQ_API_KEY_HERE
GROQ_API_KEY_2=YOUR_GROQ_API_KEY_HERE
GROQ_API_KEY_3=YOUR_GROQ_API_KEY_HERE
GROQ_API_KEY_4=YOUR_GROQ_API_KEY_HERE
GROQ_API_KEY_5=YOUR_GROQ_API_KEY_HERE
GROQ_API_KEY_6=YOUR_GROQ_API_KEY_HERE
GROQ_API_KEY_7=YOUR_GROQ_API_KEY_HERE
GROQ_ENABLE_KEY_ROTATION=true
GROQ_ROTATION_STRATEGY=round-robin
GROQ_KEY_FAILURE_THRESHOLD=3
GROQ_KEY_COOLDOWN_SECONDS=300

# Ollama Cloud - Secondary Fallback
OLLAMA_MODEL=qwen3.5:397b-cloud
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=YOUR_OLLAMA_KEY_HERE
OLLAMA_RATE_LIMIT_RPM=20
OLLAMA_RATE_LIMIT_CONCURRENT=5

# AI Router Configuration
USE_AI_ROUTING=true
AI_ROUTER_STRATEGY=priority-fallback
AI_ROUTER_PRIORITY_ORDER=9router,groq,ollama
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
CIRCUIT_BREAKER_TIMEOUT=60000
ENABLE_REQUEST_CACHING=true
CACHE_TTL_SECONDS=300

