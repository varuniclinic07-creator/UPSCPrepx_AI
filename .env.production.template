# ═══════════════════════════════════════════════════════════════
# UPSC CSE MASTER - PRODUCTION ENVIRONMENT TEMPLATE
# Copy to .env.production and fill in real values
# NEVER commit real credentials to version control
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════
# SUPABASE (Production)
# ═══════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=minimum_32_characters_secret

# ═══════════════════════════════════════════════════════════════
# AI PROVIDERS
# ═══════════════════════════════════════════════════════════════
# Primary: 9Router (Claude Sonnet)
NINE_ROUTER_API_KEY=your_9router_api_key
NINE_ROUTER_BASE_URL=https://rq9whnn.9router.com/v1
NINE_ROUTER_MODEL=kr/claude-sonnet-4-5

# Fallback: Groq
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Emergency: Ollama
OLLAMA_BASE_URL=https://your-ollama-instance.com
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_MODEL=llama3.1:8b

# Alternative: OpenCode, Kilo
OPENCODE_API_KEY=your_opencode_api_key
KILO_API_KEY=your_kilo_api_key

# ═══════════════════════════════════════════════════════════════
# REDIS (Production)
# ═══════════════════════════════════════════════════════════════
REDIS_PASSWORD=generate_with_openssl_rand_base64_32
REDIS_URL=redis://:REDIS_PASSWORD@your-redis-host:6379

# ═══════════════════════════════════════════════════════════════
# POSTGRESQL DATABASE
# ═══════════════════════════════════════════════════════════════
POSTGRES_DB=upsc_production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=generate_strong_password
DATABASE_URL=postgresql://postgres:PASSWORD@your-db-host:5432/upsc_production

# ═══════════════════════════════════════════════════════════════
# RAZORPAY PAYMENT GATEWAY
# ═══════════════════════════════════════════════════════════════
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
WEBHOOK_SECRET=your_webhook_secret

# ═══════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=generate_super_secret_jwt_key_minimum_32_characters
CRON_SECRET=generate_cron_secret_here
ENCRYPTION_KEY=generate_32_character_encryption_key
IP_HASH_SALT=generate_random_salt

# ═══════════════════════════════════════════════════════════════
# NEXTAUTH
# ═══════════════════════════════════════════════════════════════
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=generate_minimum_32_characters_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ═══════════════════════════════════════════════════════════════
# EMAIL SERVICE
# ═══════════════════════════════════════════════════════════════
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@your-domain.com

# AWS SES (Alternative)
# AWS_SES_ACCESS_KEY_ID=your_ses_access_key
# AWS_SES_SECRET_ACCESS_KEY=your_ses_secret_key
# AWS_SES_REGION=ap-south-1

# ═══════════════════════════════════════════════════════════════
# STORAGE - AWS S3
# ═══════════════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_bucket_name
MINIO_ENDPOINT=your-minio-endpoint
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ═══════════════════════════════════════════════════════════════
# ANALYTICS
# ═══════════════════════════════════════════════════════════════
SENTRY_DSN=https://your_key@sentry.io/123456
SENTRY_ENVIRONMENT=production
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://app.posthog.com

# ═══════════════════════════════════════════════════════════════
# RATE LIMITING & CACHING
# ═══════════════════════════════════════════════════════════════
ENABLE_RATE_LIMITING=true
GLOBAL_RATE_LIMIT_RPM=600
ENABLE_CACHING=true
CACHE_TTL_HOURS=24

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════
ENABLE_LECTURES=true
ENABLE_MOCK_INTERVIEWS=true
ENABLE_ESSAY_EVALUATION=true
ENABLE_VIDEO_DOWNLOAD=true
ENABLE_AI_NOTES=true
ENABLE_MIND_MAPS=true

# ═══════════════════════════════════════════════════════════════
# CORS
# ═══════════════════════════════════════════════════════════════
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ═══════════════════════════════════════════════════════════════
# VPS DEPLOYMENT (Optional)
# ═══════════════════════════════════════════════════════════════
VPS_IP=your_vps_ip
VPS_SSH_USER=root

# ═══════════════════════════════════════════════════════════════
# OPTIONAL SERVICES
# ═══════════════════════════════════════════════════════════════
# Crawl4AI
CRAWL4AI_API_TOKEN=your_crawl4ai_token

# Plausible Analytics
PLAUSIBLE_BASE_URL=https://plausible.your-domain.com
PLAUSIBLE_SECRET_KEY_BASE=generate_64_char_secret
PLAUSIBLE_DB_PASSWORD=plausible_db_password

# Mautic Marketing
MAUTIC_DB_ROOT_PASSWORD=mautic_root_password
MAUTIC_DB_PASSWORD=mautic_db_password

# Grafana Monitoring
GRAFANA_PASSWORD=generate_grafana_password

# Manim Animation
MANIM_QUALITY=high_quality

# Remotion Video
REMOTION_CONCURRENCY=4
