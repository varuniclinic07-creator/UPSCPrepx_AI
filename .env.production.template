# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════
NODE_ENV=production
APP_URL=https://upsc-cse-master.com
API_URL=https://api.upsc-cse-master.com

# Rate Limiting
ENABLE_RATE_LIMITING=true
GLOBAL_RATE_LIMIT_RPM=600  # 10 requests/sec

# Caching
ENABLE_CACHING=true
CACHE_TTL_HOURS=24

# Feature Flags
ENABLE_LECTURES=true
ENABLE_MOCK_INTERVIEWS=true
ENABLE_ESSAY_EVALUATION=true
ENABLE_VIDEO_DOWNLOAD=true

