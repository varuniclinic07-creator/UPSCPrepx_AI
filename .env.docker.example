# ═══════════════════════════════════════════════════════════════
# UPSC CSE MASTER - DOCKER ENVIRONMENT TEMPLATE
# Copy to .env.docker.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════
# SUPABASE
# ═══════════════════════════════════════════════════════════════
SUPABASE_URL=http://supabase:8000
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ═══════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════
REDIS_PASSWORD=generate_strong_password_here
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379

# ═══════════════════════════════════════════════════════════════
# RAZORPAY PAYMENT GATEWAY
# ═══════════════════════════════════════════════════════════════
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
WEBHOOK_SECRET=your_webhook_secret_here

# ═══════════════════════════════════════════════════════════════
# AI PROVIDERS
# ═══════════════════════════════════════════════════════════════
OPENCODE_API_KEY=your_opencode_api_key_here
KILO_API_KEY=your_kilo_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ═══════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=generate_super_secret_jwt_key_minimum_32_characters
CRON_SECRET=generate_cron_secret_here
ENCRYPTION_KEY=generate_32_character_encryption_key

# ═══════════════════════════════════════════════════════════════
# EMAIL SERVICE (Optional)
# ═══════════════════════════════════════════════════════════════
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# ═══════════════════════════════════════════════════════════════
# STORAGE - AWS S3 (Optional)
# ═══════════════════════════════════════════════════════════════
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=your_bucket_name

# ═══════════════════════════════════════════════════════════════
# ANALYTICS (Optional)
# ═══════════════════════════════════════════════════════════════
# POSTHOG_API_KEY=your_posthog_api_key
# POSTHOG_HOST=https://app.posthog.com

# ═══════════════════════════════════════════════════════════════
# MONITORING (Optional)
# ═══════════════════════════════════════════════════════════════
# SENTRY_DSN=https://your_key@sentry.io/123456
# SENTRY_ENVIRONMENT=production

# ═══════════════════════════════════════════════════════════════
# OPTIONAL SERVICES
# ═══════════════════════════════════════════════════════════════
# MinIO Object Storage
MINIO_ROOT_USER=your_minio_admin_user
MINIO_ROOT_PASSWORD=your_minio_password_here

# Crawl4AI Web Scraping
CRAWL4AI_API_TOKEN=your_crawl4ai_token_here

# Plausible Analytics
PLAUSIBLE_BASE_URL=http://localhost:8089
PLAUSIBLE_SECRET_KEY_BASE=generate_random_64_char_string
PLAUSIBLE_DB_PASSWORD=plausible_db_password

# Mautic Marketing
MAUTIC_DB_ROOT_PASSWORD=mautic_root_password
MAUTIC_DB_PASSWORD=mautic_db_password

# Grafana Monitoring
GRAFANA_PASSWORD=admin_password_here

# Manim Animation Service
MANIM_QUALITY=medium_quality

# Remotion Video Service
REMOTION_CONCURRENCY=2
