# UPSC Content Crawler - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Supabase Configuration (REQUIRED)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# Use service_role key for crawler (has write permissions)
# You can find these in Supabase Dashboard > Settings > API

# ============================================
# Crawler Configuration (Optional)
# ============================================

# User agent for requests
CRAWLER_USER_AGENT=UPSC-CSE-Master-Bot/1.0 (Educational Content Aggregator; +https://your-domain.com)

# Rate limiting (seconds between requests)
DEFAULT_RATE_LIMIT=3.0

# Max concurrent requests
MAX_CONCURRENT_REQUESTS=3

# Timeout for requests (seconds)
REQUEST_TIMEOUT=30

# Max retries on failure
MAX_RETRIES=3

# Respect robots.txt (true/false)
RESPECT_ROBOTS_TXT=true

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location
LOG_FILE=logs/crawler.log

# ============================================
# Storage Configuration
# ============================================

# Store raw HTML (true/false) - increases storage but preserves original
STORE_RAW_HTML=false

# Enable content compression (true/false)
ENABLE_COMPRESSION=true

# Batch size for bulk operations
STORAGE_BATCH_SIZE=100

# ============================================
# Error Handling & Alerts
# ============================================

# Max consecutive failures before alert
MAX_CONSECUTIVE_FAILURES=3

# Email notifications (optional)
ALERT_EMAIL=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ============================================
# Scheduling Configuration
# ============================================

# Time zone for scheduled tasks
TIMEZONE=Asia/Kolkata

# Run initial crawl on startup (true/false)
RUN_INITIAL_CRAWL=true

# ============================================
# Advanced Configuration
# ============================================

# Enable JavaScript rendering (requires more resources)
ENABLE_JAVASCRIPT=false

# Playwright browser type: chromium, firefox, webkit
BROWSER_TYPE=chromium

# Headless mode (true/false)
HEADLESS=true

# Screenshot failed pages (for debugging)
SCREENSHOT_ON_ERROR=false

# ============================================
# Development/Testing
# ============================================

# Enable debug mode
DEBUG=false

# Test mode (don't actually store to database)
TEST_MODE=false

# Dry run (show what would be crawled without crawling)
DRY_RUN=false
